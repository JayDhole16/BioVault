# Backend Environment Variables
# Rename this file to .env for local development

# App Configuration
APP_NAME=BioVault API
DEBUG=True

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database Configuration
DATABASE_URL=sqlite:///./biovault.db
# For MongoDB: mongodb://localhost:27017/biovault
DB_TYPE=sqlite

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# WebAuthn Configuration
RP_ID=localhost
RP_NAME=BioVault
RP_ORIGIN=http://localhost:3000

# Blockchain Configuration
HARDHAT_RPC_URL=http://127.0.0.1:8545
NETWORK=hardhat

# ML Model Configuration
MODEL_PATH=ml_models/fraud_detection_model.pkl
MODEL_SCALER_PATH=ml_models/scaler.pkl

# Fraud Detection Thresholds
FRAUD_THRESHOLD=0.5
HIGH_RISK_THRESHOLD=0.7
